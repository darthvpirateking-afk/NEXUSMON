{
  "apiBaseUrl": "http://localhost:8000",
  "uiBaseUrl": "http://localhost:8000/cockpit",
  "bind": "0.0.0.0",
  "port": 8000,
  "config_version": 2,
  "llm": {
    "cortex": {
      "provider": "openai",
      "model": "gpt-4o",
      "apiKeyEnv": "OPENAI_API_KEY",
      "purpose": "deep reasoning — strategic mode"
    },
    "reflex": {
      "provider": "groq",
      "model": "llama-3.1-70b-versatile",
      "apiKeyEnv": "GROQ_API_KEY",
      "purpose": "fast routing — combat mode"
    },
    "fallback": {
      "provider": "openai",
      "model": "gpt-4o-mini",
      "apiKeyEnv": "OPENAI_API_KEY",
      "enabled": true,
      "purpose": "fallback if primary tiers fail"
    }
  },
  "budget": {
    "strategic": 4096,
    "combat": 2048,
    "guardian": 0
  },
  "routing": {
    "default_tier": "cortex",
    "swarm_tier": "reflex",
    "offline_tier": "fallback"
  },
  "offlineMode": false,
  "models": {
    "provider": "openai",
    "anthropic": {
      "model": "claude-sonnet-4-20250514",
      "apiKeyEnv": "ANTHROPIC_API_KEY"
    },
    "openai": {
      "model": "gpt-4o",
      "apiKeyEnv": "OPENAI_API_KEY"
    },
    "groq": {
      "model": "llama-3.1-70b-versatile",
      "apiKeyEnv": "GROQ_API_KEY"
    },
    "ollama": {
      "model": "llama3.2:3b",
      "endpoint": "http://localhost:11434",
      "apiKeyEnv": ""
    },
    "gemini": {
      "model": "gemini-2.0-flash",
      "apiKeyEnv": "GEMINI_API_KEY",
      "endpoint": "https://generativelanguage.googleapis.com/v1beta"
    },
    "timeoutMs": 120000,
    "maxTokens": 2048
  },
  "companion": {
    "enabled": true,
    "sessionId": "main_companion",
    "memoryFile": "data/companion_memory.json",
    "policy": "active"
  },
  "telegram": {
    "enabled": true,
    "token_env": "TELEGRAM_BOT_TOKEN",
    "note": "Set TELEGRAM_BOT_TOKEN env var to activate. Get token from @BotFather on Telegram."
  },
  "integrations": {
    "zapier": {
      "enabled": true,
      "shared_secret": "change-me-to-a-real-secret",
      "inbound_path": "/v1/zapier/inbound",
      "emit_path": "/v1/zapier/emit",
      "zapier_catch_hook_url": ""
    }
  },
  "schema_version": 2
}
