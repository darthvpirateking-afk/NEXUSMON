{
  "testEnvironment": "node",
  "roots": ["<rootDir>/src", "<rootDir>/frontend/src"],
  "testMatch": ["**/__tests__/**/*.ts", "**/?(*.)+(spec|test).ts"],
  "transform": {
    "^.+\\.tsx?$": [
      "ts-jest",
      {
        "tsconfig": {
          "target": "ES2022",
          "module": "commonjs",
          "esModuleInterop": true,
          "moduleResolution": "node",
            "jsx": "react-jsx",
          "types": ["jest", "node"]
        },
        "diagnostics": false,
        "isolatedModules": true
      }
    ]
  },
  "collectCoverageFrom": [
    "src/**/*.ts",
    "!src/**/*.d.ts",
    "!src/example.ts"
  ]
}
