# NEXUSMON — Environment Configuration
# Copy this file to .env and fill in your values.
# The server reads .env automatically on startup (python-dotenv).

# ── LLM Providers ─────────────────────────────────────────────────────────────
# REQUIRED for AI functionality. Without these, all LLM calls fail.
# Strategic mode → OpenAI GPT-4o (cortex tier)
OPENAI_API_KEY=your-openai-key-here
# Combat mode → Groq llama-3.1-70b-versatile (reflex tier)
GROQ_API_KEY=your-groq-key-here

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8000
SWARMZ_API_HOST=0.0.0.0
SWARMZ_API_PORT=8000
SWARMZ_API_RELOAD=false

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=./data/nexusmon.db

# ── Security ──────────────────────────────────────────────────────────────────
SWARMZ_OPERATOR_PIN=changeme
# SWARMZ_API_KEY=your-api-key-here
# SWARMZ_SECRET_KEY=your-secret-key-here
# PAYMENT_WEBHOOK_SECRET=your_webhook_secret_here

# ── Mode Flags ────────────────────────────────────────────────────────────────
# Set OFFLINE_MODE=true to disable ALL LLM calls (missions run locally with no AI)
OFFLINE_MODE=false
SWARMZ_VERBOSE=false

# ── System Config ─────────────────────────────────────────────────────────────
SWARMZ_CONFIG_PATH=config.json
SWARMZ_LOG_LEVEL=INFO
SWARMZ_PLUGIN_DIR=plugins

# ── Feature Flags ─────────────────────────────────────────────────────────────
ENABLE_REALITY_GATE=true
ENABLE_MISSION_CONTRACT=true
ENABLE_LEAD_AUDIT=true

# ── CORS (optional) ───────────────────────────────────────────────────────────
# CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173

# ── Optional Services ─────────────────────────────────────────────────────────
# OLLAMA_ENDPOINT=http://localhost:11434/v1   (local LLM via Ollama)
# SENTRY_DSN=
# LOG_FILE=swarmz.log
